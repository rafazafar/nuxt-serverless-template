{
  "name": "nuxt-edge-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "deploy-cloudflare": "NITRO_PRESET=cloudflare_module npm run build && npx wrangler deploy && npx wrangler d1 migrations apply DB --remote",
    "deploy-vercel": "npx vercel deploy",
    "postinstall": "pnpx skills add antfu/skills -a codex -s nuxt -y && pnpx skills add obra/superpowers --skill using-superpowers -a codex -y && pnpx skills add onmax/nuxt-skills --skill nuxthub -a codex -y && nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/test-utils": "4.0.0",
    "@nuxt/ui": "4.5.1",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/seo": "3.4.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "nuxt-nodemailer": "1.1.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "4.62.0"
  },
  "author": "rafazafar"
}
