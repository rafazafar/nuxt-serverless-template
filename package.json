{
  "name": "nuxt-edge-template",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "deploy": "pnpm run build && pnpx wrangler deploy && pnpx wrangler d1 migrations apply DB --remote",
    "postinstall": "nuxt prepare",
    "prepare": "nlx nuxt cleanup && nlx nuxt prepare",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/ui": "4.5.1",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/i18n": "10.2.3",
    "@nuxtjs/seo": "3.4.0",
    "ai": "^6.0.116",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "nuxt-nodemailer": "1.1.4",
    "tailwindcss": "^4.2.2",
    "workers-ai-provider": "^3.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@nuxt/test-utils": "4.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6",
    "wrangler": "4.76.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
